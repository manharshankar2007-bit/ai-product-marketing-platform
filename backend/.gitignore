node_modules
dist
.env
*.log

/src/generated/prisma

# SQLite database file and its sidecar files (WAL/journal) — data, not
# schema. Migrations (prisma/migrations/) ARE committed; the .db file itself
# never is.
*.db
*.db-journal
*.db-wal
*.db-shm

/uploads/*
!/uploads/.gitkeep

# Pipeline debug instrumentation output — a diagnostic artifact regenerated
# on every run, not project state.
/debug/*.json
